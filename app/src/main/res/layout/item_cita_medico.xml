<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Fila superior: Hora + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Hora de la cita -->
            <TextView
                android:id="@+id/tvHoraCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Badge de estado -->
            <TextView
                android:id="@+id/tvEstadoCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nombre del paciente -->
        <TextView
            android:id="@+id/tvNombrePaciente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- DNI del paciente -->
        <TextView
            android:id="@+id/tvDniPaciente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Motivo de consulta -->
        <TextView
            android:id="@+id/tvMotivo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="italic" />

        <!-- Separador -->
        <View
            android:id="@+id/dividerAcciones"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#E0E0E0" />

        <!-- Botones de acción -->
        <LinearLayout
            android:id="@+id/layoutAcciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIniciarConsulta"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Iniciar Consulta"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinalizarConsulta"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="Finalizar"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@color/success"
                app:strokeColor="@color/success"
                app:cornerRadius="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Botón Crear Tratamiento (visible en citas Atendidas) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCrearTratamiento"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:text="📋 Crear Plan de Tratamiento"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textColor="@color/primary"
            android:visibility="gone"
            app:cornerRadius="10dp"
            app:strokeColor="@color/primary"
            app:icon="@android:drawable/ic_menu_agenda"
            app:iconTint="@color/primary"
            app:iconSize="18dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
