<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Fila superior: Hora + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Hora de la cita -->
            <TextView
                android:id="@+id/tvHoraCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Badge de estado -->
            <TextView
                android:id="@+id/tvEstadoCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nombre del paciente -->
        <TextView
            android:id="@+id/tvNombrePaciente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- DNI del paciente -->
        <TextView
            android:id="@+id/tvDniPaciente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Motivo de consulta -->
        <TextView
            android:id="@+id/tvMotivo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="italic" />

        <!-- Separador -->
        <View
            android:id="@+id/dividerAcciones"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#E0E0E0" />

        <!-- Botones de acción -->
        <LinearLayout
            android:id="@+id/layoutAcciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAtendida"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Atendido"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@color/success"
                app:icon="@android:drawable/checkbox_on_background"
                app:iconTint="@color/success"
                app:iconSize="16dp"
                app:rippleColor="@color/success" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNoAsistio"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="No asistió"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@color/warning"
                app:icon="@android:drawable/ic_menu_help"
                app:iconTint="@color/warning"
                app:iconSize="16dp"
                app:rippleColor="@color/warning" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelar"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@color/error"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconTint="@color/error"
                app:iconSize="16dp"
                app:rippleColor="@color/error" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
