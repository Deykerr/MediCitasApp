<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- RNF02.1: La aplicación requiere conexión a internet -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MEDICITAS">

        <!-- Splash/Router: verifica sesión y redirige -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Pantallas de Autenticación -->
        <activity
            android:name=".view.auth.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".view.auth.RegistroActivity"
            android:exported="false" />

        <activity
            android:name=".view.auth.RecuperarContrasenaActivity"
            android:exported="false" />

        <!-- Pantallas del Administrador (RF06) -->
        <activity
            android:name=".view.admin.AdminHomeActivity"
            android:exported="false" />

        <activity
            android:name=".view.admin.GestionEspecialidadesActivity"
            android:exported="false" />

        <activity
            android:name=".view.admin.GestionPostasActivity"
            android:exported="false" />

        <activity
            android:name=".view.admin.GestionPersonalActivity"
            android:exported="false" />

        <activity
            android:name=".view.admin.GestionHorariosActivity"
            android:exported="false" />

        <!-- Pantallas del Médico (RF05) -->
        <activity
            android:name=".view.doctor.MedicoHomeActivity"
            android:exported="false" />

        <activity
            android:name=".view.doctor.MisHorariosActivity"
            android:exported="false" />

        <!-- Pantallas del Paciente (RF02, RF03, RF04) -->
        <activity
            android:name=".view.patient.PacienteHomeActivity"
            android:exported="false" />

        <activity
            android:name=".view.patient.ReservaActivity"
            android:exported="false" />

        <activity
            android:name=".view.patient.MisCitasActivity"
            android:exported="false" />

        <activity
            android:name=".view.patient.MiPerfilActivity"
            android:exported="false" />

    </application>

</manifest>